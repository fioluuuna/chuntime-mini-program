page {
  background: #f7f2ea;
  color: #2f241e;
  font-size: 28rpx;
}

.page {
  padding: 24rpx 24rpx 40rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 42rpx rgba(112, 78, 42, 0.08);
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #211711;
}

.subtitle {
  font-size: 24rpx;
  color: #76685b;
  line-height: 1.5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #315a33, #49724a);
  color: #fff;
  font-weight: 600;
}

.btn-ghost {
  background: #fffaf3;
  color: #2f5d3a;
  border: 2rpx solid #e5dccd;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3efe8;
  color: #6b5a4a;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f3ecdf;
  color: #7a624d;
  font-size: 22rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.muted {
  color: #7b6d60;
}

.price {
  color: #b0371b;
  font-weight: 700;
}

.old-price {
  color: #9b8b7f;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.image {
  width: 100%;
  display: block;
  border-radius: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.space-between {
  justify-content: space-between;
}

.align-start {
  align-items: flex-start;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.soft-panel {
  background: linear-gradient(180deg, #fffaf2, #f7efe3);
  border-radius: 24rpx;
  padding: 22rpx;
}

.icon-circle {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #f2eadc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #5f4a37;
  font-weight: 700;
}

.notice-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  background: #fff;
  border-radius: 22rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(112, 78, 42, 0.05);
}

.notice-icon {
  color: #b06724;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }
