page {
  background: #fff8f1;
  color: #2f241e;
  font-size: 28rpx;
}

.page {
  padding: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(127, 88, 45, 0.08);
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #211711;
}

.subtitle {
  font-size: 24rpx;
  color: #76685b;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #3f7d4b, #2f5d3a);
  color: #fff;
  font-weight: 600;
}

.btn-ghost {
  background: #fff;
  color: #2f5d3a;
  border: 2rpx solid #d7e4d9;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3efe8;
  color: #6b5a4a;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.muted {
  color: #7b6d60;
}

.price {
  color: #b0371b;
  font-weight: 700;
}

.old-price {
  color: #9b8b7f;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.image {
  width: 100%;
  display: block;
  border-radius: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.space-between {
  justify-content: space-between;
}

.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }

