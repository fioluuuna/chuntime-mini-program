page {
  background:
    radial-gradient(circle at top, rgba(201, 126, 75, 0.14), transparent 38%),
    linear-gradient(180deg, #f8f1e8 0%, #f5ede4 52%, #f2e8dd 100%);
  color: #2f241d;
  font-size: 28rpx;
}

.page {
  padding: 24rpx 24rpx 48rpx;
}

.card {
  background: rgba(255, 252, 248, 0.94);
  border: 1rpx solid rgba(188, 154, 125, 0.14);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 48rpx rgba(99, 59, 26, 0.09);
  margin-bottom: 24rpx;
  backdrop-filter: blur(8rpx);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: #24170f;
  line-height: 1.3;
}

.subtitle {
  font-size: 24rpx;
  color: #7b6858;
  line-height: 1.7;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d1f16;
  margin-bottom: 16rpx;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 18rpx 30rpx;
  background: linear-gradient(135deg, #8f3f22, #b86130);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(184, 97, 48, 0.24);
}

.btn-ghost {
  background: rgba(255, 247, 238, 0.96);
  color: #8f3f22;
  border: 2rpx solid #ead9c7;
  box-shadow: none;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 237, 0.86);
  color: #7e5f46;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f6eadc;
  color: #8b613e;
  font-size: 22rpx;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.muted {
  color: #7b6d60;
}

.price {
  color: #b34a1f;
  font-weight: 700;
}

.old-price {
  color: #a69283;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.image {
  width: 100%;
  display: block;
  border-radius: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.space-between {
  justify-content: space-between;
}

.align-start {
  align-items: flex-start;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.soft-panel {
  background: linear-gradient(180deg, rgba(255, 249, 242, 0.95), rgba(248, 238, 226, 0.95));
  border-radius: 24rpx;
  padding: 22rpx;
}

.icon-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #fff2e5, #f6dfca);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #9d4a1c;
  font-weight: 700;
}

.notice-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 22rpx;
  background: rgba(255, 251, 246, 0.95);
  border-radius: 22rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(112, 78, 42, 0.05);
}

.notice-icon {
  color: #b06724;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: rgba(245, 237, 227, 0.95);
  border: 1rpx solid #efdfcf;
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  margin-top: 16rpx;
  color: #2f241d;
  font-size: 28rpx;
  line-height: 1.5;
}

.input {
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
}

.field-placeholder {
  color: #a59180;
  font-size: 28rpx;
}

.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-24 { margin-bottom: 24rpx; }
