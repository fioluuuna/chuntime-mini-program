.hero {
  position: relative;
  overflow: hidden;
  padding: 0;
  border-radius: 32rpx;
}

.hero-image {
  height: 420rpx;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.12), rgba(22, 12, 7, 0.78));
}

.hero-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  color: #fff;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.hero-pills {
  margin-top: 16rpx;
}

.quick-grid {
  gap: 22rpx;
}

.quick-item {
  background: linear-gradient(180deg, #fff9f1, #f8efe4);
  border-radius: 24rpx;
  padding: 20rpx;
}

.quick-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-desc {
  margin-top: 8rpx;
  color: #7b6d60;
  font-size: 22rpx;
  line-height: 1.45;
}

.feature-card {
  margin-bottom: 18rpx;
}

.feature-label {
  font-size: 28rpx;
  font-weight: 600;
}

.soup-row {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.soup-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.soup-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.soup-body {
  flex: 1;
}

.soup-name {
  font-size: 28rpx;
  font-weight: 700;
}

.route-preview {
  border: 1rpx solid #efe6da;
}

.qr-image {
  width: 280rpx;
  margin: 0 auto;
  display: block;
}
