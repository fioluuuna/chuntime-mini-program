.hero {
  position: relative;
  overflow: hidden;
  padding: 0;
  border-radius: 36rpx;
  min-height: 520rpx;
}

.hero-image {
  height: 520rpx;
}

.hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(36, 17, 9, 0.16), rgba(45, 22, 11, 0.84)),
    linear-gradient(120deg, rgba(177, 98, 49, 0.12), transparent 42%);
}

.hero-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 34rpx 30rpx 30rpx;
  color: #fff;
}

.hero-logo-area {
  display: inline-block;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 250, 245, 0.93);
}

.hero-pills {
  margin-top: 20rpx;
}

.hero-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.hero-ghost {
  color: #fff;
  border-color: rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.12);
}

.quick-grid {
  gap: 22rpx;
}

.quick-item {
  background: linear-gradient(180deg, #fff9f2, #f8eee4);
  border-radius: 28rpx;
  padding: 22rpx;
}

.quick-title {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-desc {
  margin-top: 8rpx;
  color: #7b6d60;
  font-size: 22rpx;
  line-height: 1.55;
}

.route-preview {
  border: 1rpx solid #efe2d5;
}

.signature-card {
  padding: 28rpx 28rpx 30rpx;
}

.signature-head {
  margin-bottom: 20rpx;
}

.signature-swiper-shell {
  position: relative;
}

.signature-swiper {
  height: 430rpx;
}

.signature-slide {
  position: relative;
  height: 430rpx;
  overflow: hidden;
  border-radius: 30rpx;
}

.signature-image {
  width: 100%;
  height: 100%;
  display: block;
}

.signature-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(29, 13, 7, 0.12), rgba(29, 13, 7, 0.82)),
    linear-gradient(120deg, rgba(178, 90, 42, 0.12), transparent 45%);
}

.signature-corner {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 237, 0.92);
  color: #8e451f;
  font-size: 22rpx;
  font-weight: 700;
}

.signature-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  color: #fff;
}

.signature-hot {
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 63, 34, 0.92);
  font-size: 22rpx;
  font-weight: 600;
}

.signature-name {
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.28;
}

.signature-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: rgba(255, 249, 243, 0.94);
}

.signature-price-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.signature-price {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff6ee;
}

.signature-old-price {
  font-size: 22rpx;
  color: rgba(255, 240, 230, 0.8);
}

.signature-stock {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  font-size: 22rpx;
  color: #fff;
}

.signature-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 62rpx;
  height: 62rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 250, 245, 0.78);
  color: #7b3f21;
  font-size: 42rpx;
  line-height: 1;
  z-index: 4;
  box-shadow: 0 14rpx 28rpx rgba(64, 27, 9, 0.18);
}

.signature-arrow-left {
  left: 18rpx;
}

.signature-arrow-right {
  right: 18rpx;
}

.signature-arrow-hover {
  background: rgba(245, 232, 220, 0.96);
  transform: translateY(-50%) scale(0.96);
}

.swiper-dots {
  margin-top: 18rpx;
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.swiper-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(168, 127, 93, 0.28);
}

.swiper-dot-active {
  width: 34rpx;
  border-radius: 999rpx;
  background: #a34e25;
}

.signature-note {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8d7058;
}

.fresh-visual-card {
  overflow: hidden;
}

.fresh-visual-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.9fr;
  gap: 18rpx;
}

.fresh-visual-main,
.fresh-visual-side-item {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
}

.fresh-visual-side {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.fresh-visual-image {
  width: 100%;
  display: block;
}

.main-image {
  height: 420rpx;
}

.side-image {
  height: 201rpx;
}

.fresh-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(22, 12, 7, 0.08), rgba(22, 12, 7, 0.72));
}

.fresh-overlay-text {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  color: #fff;
}

.side-text {
  bottom: 16rpx;
}

.fresh-overlay-tag {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 600;
}

.fresh-overlay-title {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.56;
  font-weight: 700;
}

.contact-qr {
  width: 280rpx;
  display: block;
  margin: 8rpx auto 0;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(29, 17, 10, 0.38);
  z-index: 99;
}

.owner-modal {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fffdf9;
  border-radius: 28rpx;
  padding: 30rpx;
  z-index: 100;
  box-shadow: 0 24rpx 60rpx rgba(60, 30, 10, 0.22);
}

.owner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2a1b12;
}

.owner-input {
  margin-top: 22rpx;
}

.owner-actions {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
