.hero {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.hero-image {
  height: 360rpx;
}

.hero-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(21, 12, 7, 0.72));
  color: #fff;
}

.quick {
  min-height: 150rpx;
}

.feature-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0ebe5;
}

.feature-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.feature-label {
  font-size: 28rpx;
  font-weight: 600;
}

.soup-row {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.soup-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.soup-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.soup-body {
  flex: 1;
}

.soup-name {
  font-size: 28rpx;
  font-weight: 700;
}

.route-preview {
  border: 1rpx solid #efe6da;
}

