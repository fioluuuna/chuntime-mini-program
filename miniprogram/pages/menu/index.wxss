.menu-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.menu-body {
  flex: 1;
}

.menu-name {
  font-size: 28rpx;
  font-weight: 700;
}

.sticky-summary {
  position: sticky;
  bottom: 28rpx;
  z-index: 10;
}
