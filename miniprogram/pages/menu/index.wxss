.menu-shell {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.menu-sidebar {
  width: 144rpx;
  position: sticky;
  top: 24rpx;
}

.category-item {
  padding: 24rpx 14rpx;
  margin-bottom: 14rpx;
  border-radius: 26rpx;
  background: rgba(245, 236, 225, 0.96);
  color: #6d5a49;
  text-align: center;
  font-weight: 600;
  box-shadow: inset 0 0 0 1rpx rgba(199, 169, 141, 0.14);
}

.category-item-active {
  background: linear-gradient(180deg, #8f3f22, #b86130);
  color: #fff;
  box-shadow: 0 14rpx 28rpx rgba(184, 97, 48, 0.22);
}

.menu-content-scroll {
  flex: 1;
  min-width: 0;
  height: calc(100vh - 300rpx);
}

.menu-content {
  padding-bottom: 8rpx;
}

.content-card {
  margin-bottom: 18rpx;
}

.menu-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1e8de;
}

.menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-image {
  width: 152rpx;
  height: 152rpx;
  border-radius: 22rpx;
  flex: 0 0 auto;
  background: #f6ecdf;
}

.menu-body {
  flex: 1;
  min-width: 0;
}

.menu-name {
  font-size: 28rpx;
  font-weight: 700;
  flex: 1;
  padding-right: 14rpx;
}

.add-btn {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ff9f42, #eb7d24);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.add-btn-disabled {
  background: #d8cec1;
  font-size: 22rpx;
}

.combo-section {
  margin-top: 24rpx;
}

.combo-label {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.choice-chip {
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f6eee4;
  color: #6f5d4f;
  font-size: 22rpx;
}

.choice-chip-active {
  background: #8f3f22;
  color: #fff;
}

.choice-chip-disabled {
  opacity: 0.45;
}

.combo-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #eadfce;
}

.combo-row:last-child {
  border-bottom: none;
}

.sticky-summary {
  position: sticky;
  bottom: 18rpx;
  z-index: 10;
}
