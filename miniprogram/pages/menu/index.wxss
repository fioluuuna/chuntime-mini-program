.menu-page {
  padding-bottom: 170rpx;
}

.menu-top-card {
  margin-bottom: 18rpx;
}

.menu-shell {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.menu-sidebar {
  width: 144rpx;
  position: sticky;
  top: 24rpx;
  align-self: flex-start;
}

.category-item {
  padding: 24rpx 14rpx;
  margin-bottom: 14rpx;
  border-radius: 26rpx;
  background: rgba(245, 236, 225, 0.96);
  color: #6d5a49;
  text-align: center;
  font-weight: 600;
  box-shadow: inset 0 0 0 1rpx rgba(199, 169, 141, 0.14);
}

.category-item-active {
  background: linear-gradient(180deg, #8f3f22, #b86130);
  color: #fff;
  box-shadow: 0 14rpx 28rpx rgba(184, 97, 48, 0.22);
}

.menu-content {
  flex: 1;
  min-width: 0;
}

.content-card {
  margin-bottom: 18rpx;
}

.menu-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1e8de;
}

.menu-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.menu-image {
  width: 152rpx;
  height: 152rpx;
  border-radius: 22rpx;
  flex: 0 0 auto;
  background: #f6ecdf;
}

.menu-body {
  flex: 1;
  min-width: 0;
}

.menu-name {
  font-size: 28rpx;
  font-weight: 700;
  flex: 1;
  padding-right: 14rpx;
}

.add-btn {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ff9f42, #eb7d24);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.add-btn-disabled {
  background: #d8cec1;
  font-size: 22rpx;
}

.combo-card {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1e8de;
}

.combo-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.combo-image {
  width: 152rpx;
  height: 152rpx;
  border-radius: 22rpx;
  background: #f6ecdf;
  flex: 0 0 auto;
}

.combo-body {
  flex: 1;
  min-width: 0;
}

.combo-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  padding-right: 14rpx;
}

.combo-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.combo-tag {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f8ead8;
  color: #8a552c;
  font-size: 22rpx;
}

.combo-tag-light {
  background: #f3f1eb;
  color: #6f6257;
}

.combo-btn {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.combo-btn-disabled {
  opacity: 0.45;
}

.sticky-summary {
  position: sticky;
  bottom: 18rpx;
  z-index: 10;
}

.combo-modal {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  max-height: 78vh;
  overflow-y: auto;
  border-radius: 32rpx;
  background: #fffdf9;
  padding: 26rpx;
  z-index: 110;
  box-shadow: 0 24rpx 56rpx rgba(53, 29, 15, 0.22);
}

.combo-close {
  padding-left: 22rpx;
  padding-right: 22rpx;
}

.combo-select-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #342217;
}

.combo-option-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.combo-option {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #f8f1e8;
  border: 2rpx solid transparent;
}

.combo-option-active {
  border-color: #b86130;
  background: #fff6ee;
}

.combo-option-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  flex: 0 0 auto;
}

.combo-option-body {
  flex: 1;
  min-width: 0;
}

.combo-option-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  padding-right: 14rpx;
}

.combo-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #eadfce;
}

.combo-row:last-child {
  border-bottom: none;
}
