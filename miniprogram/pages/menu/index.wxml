<view class="page">
  <view class="card">
    <image class="image" src="{{poster}}" mode="widthFix" bindtap="previewPoster"></image>
    <view class="mt-16">
      <view class="section-title">开业活动</view>
      <view class="muted">{{shop.openingDiscountText}}</view>
      <view class="muted">配送范围：{{shop.deliveryAreas[0]}} / {{shop.deliveryAreas[1]}} / {{shop.deliveryAreas[2]}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">汤品</view>
    <view wx:for="{{soups}}" wx:key="id" class="menu-item">
      <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="menu-body">
        <view class="row space-between">
          <view class="menu-name">{{item.name}}</view>
          <view class="price">¥{{item.salePrice}}</view>
        </view>
        <view class="muted">{{item.desc}}</view>
        <view class="muted mt-12">原价 ¥{{item.originalText}} · 库存 {{item.stock}} 份</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">主食面条</view>
    <view wx:for="{{noodles}}" wx:key="id" class="menu-item">
      <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="menu-body">
        <view class="row space-between">
          <view class="menu-name">{{item.name}}</view>
          <view class="price">¥{{item.salePrice}}</view>
        </view>
        <view class="muted">{{item.desc}}</view>
        <view class="muted mt-12">原价 ¥{{item.originalText}}</view>
      </view>
    </view>
  </view>
</view>

