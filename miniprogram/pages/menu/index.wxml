<view class="page menu-page">
  <view class="card menu-top-card">
    <view class="section-head">
      <view>
        <view class="title">今天想喝什么</view>
        <view class="subtitle">汤、面、套餐都能直接点。套餐会自动按你选的汤计算价格，不用再写备注说明。</view>
      </view>
      <view class="tag">{{shop.openingDiscountText}}</view>
    </view>
    <view class="pill">{{shop.hours}}</view>
    <view class="pill">配送区域：{{shop.deliveryAreas[0]}} / {{shop.deliveryAreas[1]}} / {{shop.deliveryAreas[2]}}</view>
    <view class="pill">配送费 ¥{{shop.deliveryFee}}</view>
  </view>

  <view class="menu-shell">
    <view class="menu-sidebar">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{activeCategory === item.key ? 'category-item-active' : ''}}"
        bindtap="selectCategory"
        data-key="{{item.key}}"
      >
        {{item.label}}
      </view>
    </view>

    <view class="menu-content">
      <view class="card content-card section-anchor" id="section-soup">
        <view class="section-head">
          <view class="section-title">炖汤</view>
          <view class="muted">显示剩余份数</view>
        </view>
        <view wx:for="{{soups}}" wx:key="id" class="menu-item">
          <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="menu-body">
            <view class="row space-between align-start">
              <view class="menu-name">{{item.name}}</view>
              <view class="price">¥{{item.salePriceText}}</view>
            </view>
            <view class="muted mt-8">{{item.desc}}</view>
            <view class="row space-between mt-12 align-start">
              <view class="muted">门市价 ¥{{item.basePriceText}} · 剩余 {{item.stock}} 份</view>
              <view class="add-btn {{item.soldOut ? 'add-btn-disabled' : ''}}" bindtap="addById" data-id="{{item.id}}">
                {{item.soldOut ? '售罄' : '+'}}
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="card content-card section-anchor" id="section-noodle">
        <view class="section-head">
          <view class="section-title">面食</view>
          <view class="muted">也可以单独点</view>
        </view>
        <view wx:for="{{noodles}}" wx:key="id" class="menu-item">
          <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="menu-body">
            <view class="row space-between align-start">
              <view class="menu-name">{{item.name}}</view>
              <view class="price">¥{{item.salePriceText}}</view>
            </view>
            <view class="muted mt-8">{{item.desc}}</view>
            <view class="row space-between mt-12 align-start">
              <view class="muted">门市价 ¥{{item.basePriceText}} · 剩余 {{item.stock}} 份</view>
              <view class="add-btn {{item.soldOut ? 'add-btn-disabled' : ''}}" bindtap="addById" data-id="{{item.id}}">
                {{item.soldOut ? '售罄' : '+'}}
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="card content-card section-anchor" id="section-combo">
        <view class="section-title">套餐</view>
        <view class="muted">先选套餐，再选符合条件的汤，系统会自动算好价格。</view>

        <view wx:for="{{combos}}" wx:key="id" class="combo-card">
          <image class="combo-image" src="{{item.noodleImage}}" mode="aspectFill"></image>
          <view class="combo-body">
            <view class="row space-between align-start">
              <view class="combo-name">{{item.name}}</view>
              <view class="price">¥{{item.startingPriceText}} 起</view>
            </view>
            <view class="muted mt-8">{{item.desc}}</view>
            <view class="combo-tags mt-16">
              <view class="combo-tag">{{item.noodleName}}</view>
              <view class="combo-tag combo-tag-light">{{item.limitText}}</view>
            </view>
            <view class="row space-between mt-16 align-start">
              <view class="muted">{{item.noodleDesc}}</view>
              <view class="btn combo-btn {{item.isAvailable ? '' : 'combo-btn-disabled'}}" bindtap="openCombo" data-id="{{item.id}}">
                {{item.isAvailable ? '选汤加入' : '暂不可点'}}
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card sticky-summary">
    <view class="row space-between">
      <view>
        <view class="section-title">购物车</view>
        <view class="muted">共 {{cartCount}} 件 · 小计 ¥{{cartTotalText}}</view>
      </view>
      <view class="btn" bindtap="goCheckout">去结算</view>
    </view>
  </view>

  <view class="mask" wx:if="{{showComboPicker}}" bindtap="closeComboPicker"></view>
  <view class="combo-modal" wx:if="{{showComboPicker}}">
    <view class="section-head">
      <view>
        <view class="section-title">{{activeCombo.name}}</view>
        <view class="muted">{{activeCombo.limitText}}</view>
      </view>
      <view class="btn btn-ghost combo-close" bindtap="closeComboPicker">关闭</view>
    </view>

    <view class="combo-select-title">选一份汤</view>
    <view class="combo-option-list">
      <view
        wx:for="{{comboSoupOptions}}"
        wx:key="id"
        class="combo-option {{selectedComboSoupId === item.id ? 'combo-option-active' : ''}}"
        bindtap="chooseComboSoup"
        data-id="{{item.id}}"
      >
        <image class="combo-option-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="combo-option-body">
          <view class="row space-between align-start">
            <view class="combo-option-name">{{item.name}}</view>
            <view class="price">¥{{item.salePriceText}}</view>
          </view>
          <view class="muted mt-8">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <view class="soft-panel mt-20" wx:if="{{comboDraft}}">
      <view class="combo-row"><text>套餐</text><text>{{comboDraft.combo.name}}</text></view>
      <view class="combo-row"><text>面食</text><text>{{comboDraft.combo.noodleName}}</text></view>
      <view class="combo-row"><text>汤品</text><text>{{comboDraft.soup.name}}</text></view>
      <view class="combo-row"><text>门市价</text><text>¥{{comboDraft.originalText}}</text></view>
      <view class="combo-row"><text>折后价</text><text class="price">¥{{comboDraft.finalText}}</text></view>
      <view class="combo-row"><text>本单已省</text><text>¥{{comboDraft.savingsText}}</text></view>
      <view class="btn mt-20" bindtap="confirmComboAdd">加入购物车</view>
    </view>
  </view>
</view>
