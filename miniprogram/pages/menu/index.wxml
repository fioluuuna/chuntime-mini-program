<view class="page menu-page">
  <view class="card menu-top-card">
    <view class="section-head">
      <view>
        <view class="title">今天想喝什么</view>
        <view class="subtitle">先选汤，再决定要不要加面。套餐支持直接搭配一个汤和一个面，系统自动算价。</view>
      </view>
      <view class="tag">{{shop.openingDiscountText}}</view>
    </view>
    <view class="pill">{{shop.hours}}</view>
    <view class="pill">配送区域：{{shop.deliveryAreas[0]}} / {{shop.deliveryAreas[1]}} / {{shop.deliveryAreas[2]}}</view>
    <view class="pill">配送费 ¥{{shop.deliveryFee}}</view>
  </view>

  <view class="menu-shell">
    <view class="menu-sidebar">
      <view
        wx:for="{{categories}}"
        wx:key="key"
        class="category-item {{activeCategory === item.key ? 'category-item-active' : ''}}"
        bindtap="selectCategory"
        data-key="{{item.key}}"
      >
        {{item.label}}
      </view>
    </view>

    <view class="menu-content">
      <view class="card content-card section-anchor" id="section-soup">
        <view class="section-head">
          <view class="section-title">炖汤</view>
          <view class="muted">显示剩余份数</view>
        </view>
        <view wx:for="{{soups}}" wx:key="id" class="menu-item">
          <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="menu-body">
            <view class="row space-between align-start">
              <view class="menu-name">{{item.name}}</view>
              <view class="price">¥{{item.salePriceText}}</view>
            </view>
            <view class="muted mt-8">{{item.desc}}</view>
            <view class="row space-between mt-12 align-start">
              <view class="muted">原价 ¥{{item.originalText}} · 剩余 {{item.stock}} 份</view>
              <view class="add-btn {{item.soldOut ? 'add-btn-disabled' : ''}}" bindtap="addById" data-id="{{item.id}}">
                {{item.soldOut ? '售罄' : '+'}}
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="card content-card section-anchor" id="section-noodle">
        <view class="section-head">
          <view class="section-title">面食</view>
          <view class="muted">也可以单独点</view>
        </view>
        <view wx:for="{{noodles}}" wx:key="id" class="menu-item">
          <image class="menu-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="menu-body">
            <view class="row space-between align-start">
              <view class="menu-name">{{item.name}}</view>
              <view class="price">¥{{item.salePriceText}}</view>
            </view>
            <view class="muted mt-8">{{item.desc}}</view>
            <view class="row space-between mt-12 align-start">
              <view class="muted">原价 ¥{{item.originalText}} · 剩余 {{item.stock}} 份</view>
              <view class="add-btn {{item.soldOut ? 'add-btn-disabled' : ''}}" bindtap="addById" data-id="{{item.id}}">
                {{item.soldOut ? '售罄' : '+'}}
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="card content-card section-anchor" id="section-combo">
        <view class="section-title">套餐</view>
        <view class="muted">任意选 1 份汤 + 1 份面，不需要备注，系统会直接算好价格。</view>

        <view class="combo-section">
          <view class="combo-label">先选汤</view>
          <view class="chip-wrap">
            <view
              wx:for="{{soups}}"
              wx:key="id"
              class="choice-chip {{selectedSoupId === item.id ? 'choice-chip-active' : ''}} {{item.soldOut ? 'choice-chip-disabled' : ''}}"
              bindtap="chooseComboSoup"
              data-id="{{item.id}}"
            >
              {{item.name}}
            </view>
          </view>
        </view>

        <view class="combo-section">
          <view class="combo-label">再选面</view>
          <view class="chip-wrap">
            <view
              wx:for="{{noodles}}"
              wx:key="id"
              class="choice-chip {{selectedNoodleId === item.id ? 'choice-chip-active' : ''}} {{item.soldOut ? 'choice-chip-disabled' : ''}}"
              bindtap="chooseComboNoodle"
              data-id="{{item.id}}"
            >
              {{item.name}}
            </view>
          </view>
        </view>

        <view class="soft-panel mt-20" wx:if="{{comboSummary}}">
          <view class="combo-row"><text>汤品</text><text>{{comboSummary.soup.name}}</text></view>
          <view class="combo-row"><text>面食</text><text>{{comboSummary.noodle.name}}</text></view>
          <view class="combo-row"><text>原价</text><text>¥{{comboSummary.originalText}}</text></view>
          <view class="combo-row"><text>折后</text><text class="price">¥{{comboSummary.finalText}}</text></view>
          <view class="combo-row"><text>本单立省</text><text>¥{{comboSummary.savingsText}}</text></view>
          <view class="btn mt-20" bindtap="addCombo">加入套餐</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card sticky-summary">
    <view class="row space-between">
      <view>
        <view class="section-title">购物车</view>
        <view class="muted">共 {{cartCount}} 件 · 小计 ¥{{cartTotalText}}</view>
      </view>
      <view class="btn" bindtap="goCheckout">去结算</view>
    </view>
  </view>
</view>
