.empty-cart,
.orders-empty {
  padding: 36rpx 0 20rpx;
  text-align: center;
}

.empty-illus {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #f5ede2;
  color: #9d7b55;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
}

.empty-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.cart-row,
.order-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.cart-row {
  display: flex;
  gap: 18rpx;
}

.cart-row:last-child,
.order-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cart-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.cart-body,
.order-main {
  flex: 1;
  min-width: 0;
}

.cart-name,
.order-id {
  font-size: 28rpx;
  font-weight: 700;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: #f4ede3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-value {
  min-width: 48rpx;
  text-align: center;
}

.radio-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-right: 24rpx;
  margin-bottom: 20rpx;
}

.field-input {
  height: 92rpx;
  padding-top: 0;
  padding-bottom: 0;
}

.remark-area {
  min-height: 180rpx;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.choice-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f5eee4;
  color: #6f5d4f;
  font-size: 22rpx;
}

.choice-chip-active {
  background: #8f3f22;
  color: #fff;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #efe4d8;
}

.result-row:last-child {
  border-bottom: none;
}

.status {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-pending_payment {
  background: #fff0db;
  color: #c26b1a;
}

.status-pending_confirm {
  background: #eef4ff;
  color: #3d62a8;
}

.status-completed {
  background: #eef6ef;
  color: #35613d;
}

.order-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.order-address {
  line-height: 1.6;
  white-space: normal;
  word-break: break-all;
}
