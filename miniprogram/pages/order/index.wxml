<view class="page">
  <view class="card">
    <view class="section-head">
      <view>
        <view class="title">订单</view>
        <view class="subtitle">先下单，再扫码付款，付款后点“我已付款”等店长确认。</view>
      </view>
      <view class="tag">{{serviceMode === 'local' ? '演示模式' : '联调模式'}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-head">
      <view class="section-title">当前购物车</view>
      <view class="muted">折扣自动结算</view>
    </view>
    <view wx:if="{{cart.length === 0}}" class="empty-cart">
      <view class="empty-illus">汤</view>
      <view class="empty-title">购物车还是空的</view>
      <view class="muted mt-8">先去点单页挑一份汤，或者直接选套餐。</view>
      <view class="btn btn-ghost mt-20" bindtap="goMenu">去点单</view>
    </view>
    <view wx:for="{{cart}}" wx:key="id" class="cart-row">
      <image class="cart-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="cart-body">
        <view class="row space-between">
          <view class="cart-name">{{item.productName}}</view>
          <view class="price">¥{{item.price}}</view>
        </view>
        <view wx:if="{{item.parts && item.parts.length}}" class="muted mt-8">
          {{item.parts[0].productName}} + {{item.parts[1].productName}}
        </view>
        <view class="row mt-12">
          <view class="qty-btn" bindtap="minusItem" data-id="{{item.id}}">-</view>
          <view class="qty-value">{{item.quantity}}</view>
          <view class="qty-btn" bindtap="plusItem" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">配送信息</view>
    <radio-group bindchange="changeFulfillment">
      <label class="radio-item">
        <radio value="配送" checked="{{fulfillmentType === '配送'}}" />
        <text>配送</text>
      </label>
      <label class="radio-item">
        <radio value="自提" checked="{{fulfillmentType === '自提'}}" />
        <text>自提</text>
      </label>
    </radio-group>

    <input class="input" placeholder="联系人" value="{{customerName}}" data-field="customerName" bindinput="bindInput" />
    <input class="input" placeholder="手机号" value="{{phone}}" data-field="phone" bindinput="bindInput" />
    <input class="input" placeholder="配送地址或自提说明" value="{{address}}" data-field="address" bindinput="bindInput" />
    <view wx:if="{{fulfillmentType === '配送'}}" class="chip-wrap mt-16">
      <view
        wx:for="{{areaOptions}}"
        wx:key="*this"
        class="choice-chip {{address === item ? 'choice-chip-active' : ''}}"
        bindtap="chooseArea"
        data-area="{{item}}"
      >
        {{item}}
      </view>
    </view>
    <textarea class="textarea" placeholder="备注，比如少辣、到店前联系我" value="{{remark}}" data-field="remark" bindinput="bindInput"></textarea>
  </view>

  <view class="card">
    <view class="section-title">结算汇总</view>
    <view class="result-row"><text>原价小计</text><text>¥{{totals.subtotalText}}</text></view>
    <view class="result-row"><text>折后小计</text><text>¥{{totals.discountedSubtotalText}}</text></view>
    <view class="result-row"><text>配送费</text><text>¥{{totals.shippingText}}</text></view>
    <view class="result-row"><text>本单已省</text><text>¥{{totals.savingsText}}</text></view>
    <view class="result-row"><text>应付金额</text><text class="price">¥{{totals.totalText}}</text></view>
    <view class="btn mt-20" bindtap="submitOrder">提交订单并去付款</view>
  </view>

  <view class="card">
    <view class="section-head">
      <view class="section-title">我的订单</view>
      <view class="muted">这里只显示你自己提交过的订单</view>
    </view>
    <view wx:if="{{myOrders.length === 0}}" class="orders-empty">
      <view class="empty-illus">单</view>
      <view class="muted mt-12">你还没有自己的订单记录</view>
    </view>
    <view wx:for="{{myOrders}}" wx:key="id" class="order-row">
      <view class="row space-between align-start">
        <view class="order-main">
          <view class="order-id">{{item.id}} · {{item.fulfillmentType}}</view>
          <view class="muted mt-8">{{item.createdAt}}</view>
          <view class="muted mt-8">金额 ¥{{item.totals.total}}</view>
        </view>
        <view class="status status-{{item.statusClass}}">{{item.status}}</view>
      </view>
      <view class="order-actions mt-16">
        <view wx:if="{{item.status === '待付款'}}" class="btn btn-ghost" bindtap="goPayment" data-id="{{item.id}}">去付款</view>
        <view wx:elif="{{item.status === '待确认'}}" class="muted">已提交付款，等待店长确认收款</view>
        <view wx:else class="muted">订单已完成，可继续下单</view>
      </view>
    </view>
  </view>
</view>
