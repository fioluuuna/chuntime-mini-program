<view class="page">
  <view class="card">
    <view class="section-title">汤 + 面自由搭</view>
    <view class="muted">先选汤，再选面，价格自动算好，不用写备注。</view>
  </view>

  <view class="card">
    <view class="section-title">选择汤品</view>
    <picker mode="selector" range="{{soups}}" range-key="name" bindchange="changeSoup">
      <view class="picker-box">
        {{soups[soupIndex].name}} · ¥{{soups[soupIndex].price}}
      </view>
    </picker>
  </view>

  <view class="card">
    <view class="section-title">选择面食</view>
    <picker mode="selector" range="{{noodles}}" range-key="name" bindchange="changeNoodle">
      <view class="picker-box">
        {{noodles[noodleIndex].name}} · ¥{{noodles[noodleIndex].price}}
      </view>
    </picker>
  </view>

  <view class="card" wx:if="{{summary}}">
    <view class="section-title">自动计价结果</view>
    <view class="result-row"><text>汤品</text><text>{{summary.soupName}} ¥{{summary.soupPrice}}</text></view>
    <view class="result-row"><text>面食</text><text>{{summary.noodleName}} ¥{{summary.noodlePrice}}</text></view>
    <view class="result-row"><text>原价合计</text><text>¥{{summary.original}}</text></view>
    <view class="result-row"><text>优惠后</text><text class="price">¥{{summary.final}}</text></view>
    <view class="result-row"><text>本单优惠</text><text>省 ¥{{summary.savings}}</text></view>
  </view>

  <view class="card">
    <view class="muted">开业 88 折期间，组合套餐会自动按折扣计算。</view>
  </view>
</view>

