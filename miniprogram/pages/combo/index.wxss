.picker-box {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f6f1ea;
  border: 1rpx solid #eadfce;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx dashed #f0e7dd;
}

.result-row:last-child {
  border-bottom: none;
}

.row {
  gap: 16rpx;
}
