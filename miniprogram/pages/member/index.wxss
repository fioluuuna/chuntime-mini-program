.member-card {
  background: linear-gradient(135deg, #354f2e, #5b8e49);
  color: #fff;
}

.member-level {
  margin-top: 20rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  margin: 12rpx 0;
}

.coupon-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.coupon-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

