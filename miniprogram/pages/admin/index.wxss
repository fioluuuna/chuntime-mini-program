.stat-card {
  min-height: 160rpx;
}

.stat-label {
  color: #7c6b5d;
  font-size: 24rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.stock-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.stock-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.stock-name {
  font-weight: 700;
  margin-bottom: 6rpx;
}

.stock-controls {
  display: flex;
  gap: 12rpx;
}

.stock-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #f4ede3;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
}

.action-item {
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8f4ee;
}

.action-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.order-admin-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.order-admin-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.status-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef6ef;
  color: #35613d;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.status-btn {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f7f2ea;
  color: #5d4a39;
  font-size: 22rpx;
}
