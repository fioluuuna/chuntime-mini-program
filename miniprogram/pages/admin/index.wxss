.stat-card {
  min-height: 160rpx;
}

.stat-label {
  color: #7c6b5d;
  font-size: 24rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.alert-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fff2df, #ffead4);
}

.alert-title {
  color: #be6719;
  font-size: 28rpx;
  font-weight: 700;
}

.module-chips,
.order-filters,
.manage-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.module-chip,
.filter-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f2ea;
  color: #5d4a39;
  font-size: 22rpx;
}

.module-chip-active,
.filter-chip-active {
  background: #315a33;
  color: #fff;
}

.manage-row,
.order-admin-row,
.analytics-block,
.ledger-entry {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.manage-row:last-child,
.order-admin-row:last-child,
.analytics-block:last-child,
.ledger-entry:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.manage-row {
  display: flex;
  gap: 18rpx;
}

.manage-row-no-image {
  display: block;
}

.thumb-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 22rpx;
  background: #f4ede4;
  flex: 0 0 auto;
}

.manage-body {
  flex: 1;
  min-width: 0;
}

.manage-title,
.stock-name,
.editor-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2b1d13;
}

.status-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-pill-pending-payment {
  background: #fff0db;
  color: #be6719;
}

.status-pill-pending-confirm {
  background: #eef4ff;
  color: #3d62a8;
}

.status-pill-completed,
.status-pill-normal {
  background: #eef6ef;
  color: #35613d;
}

.status-pill-warning {
  background: #ffe2de;
  color: #c84733;
}

.status-pill-inactive {
  background: #f0ece6;
  color: #816f5f;
}

.action-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f5eee4;
  color: #6a5444;
  font-size: 22rpx;
}

.action-chip-primary {
  background: #315a33;
  color: #fff;
}

.action-chip-danger {
  background: #fff0ef;
  color: #c84733;
}

.material-group {
  margin-top: 24rpx;
}

.material-group:first-of-type {
  margin-top: 12rpx;
}

.material-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.material-group-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #37261b;
}

.order-detail {
  flex: 1;
  min-width: 0;
}

.order-text {
  white-space: normal;
  word-break: break-all;
  line-height: 1.6;
}

.ledger-panel {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #fffaf5, #f8f1e8);
}

.ledger-head {
  margin-bottom: 18rpx;
}

.picker-chip {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5b4738;
  font-size: 22rpx;
  box-shadow: 0 8rpx 20rpx rgba(111, 78, 46, 0.08);
}

.ledger-summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.ledger-summary-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fffdf9;
  box-shadow: 0 10rpx 24rpx rgba(111, 78, 46, 0.06);
}

.ledger-summary-label {
  color: #8a7562;
  font-size: 22rpx;
}

.ledger-summary-value {
  margin-top: 14rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #2f241b;
}

.ledger-form-grid,
.ledger-lists {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.ledger-form-card,
.ledger-list-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fffdf9;
  box-shadow: inset 0 0 0 1rpx rgba(207, 186, 162, 0.28);
}

.ledger-form-title,
.analytics-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #38281e;
}

.analytics-title {
  margin-bottom: 12rpx;
}

.picker-field {
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  background: #f7f0e7;
  color: #5f4c3c;
  font-size: 24rpx;
}

.ledger-entry-main {
  flex: 1;
  min-width: 0;
}

.ledger-amount {
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 18rpx;
}

.income-text {
  color: #2f7a45;
}

.expense-text {
  color: #c84733;
}

.analytics-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  color: #6f5d4f;
}

.btn-warm {
  background: linear-gradient(180deg, #d18a4a, #b8662d);
}

.editor-modal,
.order-detail-modal {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fffdf9;
  border-radius: 30rpx;
  padding: 26rpx;
  z-index: 120;
  box-shadow: 0 24rpx 56rpx rgba(53, 29, 15, 0.24);
}

.order-detail-modal {
  max-height: 76vh;
  overflow-y: auto;
}

.editor-scroll {
  height: 760rpx;
}

.editor-preview {
  width: 100%;
  height: 260rpx;
  border-radius: 24rpx;
  background: #f4ede4;
}

.editor-image-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.editor-footer {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.order-items-block {
  margin-top: 24rpx;
}

.detail-item-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f2ebe3;
}

.detail-item-row:last-child {
  border-bottom: none;
}

.order-detail-name {
  flex: 1;
  min-width: 0;
  font-weight: 700;
}
