<view class="page">
  <view class="card">
    <view class="section-head">
      <view>
        <view class="title">店长后台</view>
        <view class="subtitle">顾客端看不到这里。这里专门处理订单、库存、耗材和日报。</view>
      </view>
      <view class="btn btn-ghost" bindtap="logout">退出</view>
    </view>

    <view wx:if="{{supplyAlerts.length}}" class="alert-box">
      <view class="alert-title">耗材预警</view>
      <view wx:for="{{supplyAlerts}}" wx:key="id" class="muted mt-8">
        {{item.name}} 仅剩 {{item.stock}}{{item.unit}}，低于预警线 {{item.warningLine}}{{item.unit}}
      </view>
    </view>
  </view>

  <view class="grid-2">
    <view class="card stat-card" wx:for="{{summaryCards}}" wx:key="label">
      <view class="stat-label">{{item.label}}</view>
      <view class="stat-value">{{item.value}}</view>
    </view>
  </view>

  <view class="card">
    <view class="module-chips">
      <view class="module-chip {{activeModule === 'orders' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="orders">订单管理</view>
      <view class="module-chip {{activeModule === 'products' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="products">菜品库存</view>
      <view class="module-chip {{activeModule === 'supplies' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="supplies">耗材管理</view>
      <view class="module-chip {{activeModule === 'report' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="report">日报统计</view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'orders'}}">
    <view class="section-head">
      <view class="section-title">订单管理</view>
      <view class="order-filters">
        <view class="filter-chip {{orderFilter === 'all' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="all">全部</view>
        <view class="filter-chip {{orderFilter === 'pending_payment' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="pending_payment">待付款</view>
        <view class="filter-chip {{orderFilter === 'pending_confirm' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="pending_confirm">待确认</view>
        <view class="filter-chip {{orderFilter === 'completed' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="completed">已完成</view>
      </view>
    </view>
    <view wx:for="{{visibleOrders}}" wx:key="id" class="order-admin-row">
      <view class="row space-between align-start">
        <view class="order-detail">
          <view class="stock-name">{{item.id}} · {{item.name}}</view>
          <view class="muted mt-8">{{item.fulfillmentText}} · {{item.phone}}</view>
          <view class="muted mt-8 order-text">地址：{{item.address}}</view>
          <view wx:if="{{item.remark}}" class="muted mt-8 order-text">备注：{{item.remark}}</view>
          <view class="muted mt-8">{{item.createdAt}} · 金额 ¥{{item.totals.total}}</view>
        </view>
        <view class="status-pill status-pill-{{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="status-actions mt-16">
        <view wx:if="{{item.status === 'pending_payment'}}" class="status-btn">等待顾客付款</view>
        <view wx:if="{{item.status === 'pending_confirm'}}" class="status-btn status-btn-primary" bindtap="stepOrder" data-id="{{item.id}}" data-status="completed">确认收款</view>
        <view wx:if="{{item.status !== 'completed'}}" class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="completed">直接完成</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'products'}}">
    <view class="section-title">菜品库存管理</view>
    <view wx:for="{{stocks}}" wx:key="id" class="stock-row">
      <view class="row space-between">
        <view>
          <view class="stock-name">{{item.name}}</view>
          <view class="muted">{{item.category === 'soup' ? '炖汤' : '面食'}} · 当前库存 {{item.stock}}</view>
        </view>
        <view class="stock-controls">
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="-1">-</view>
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="1">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'supplies'}}">
    <view class="section-head">
      <view class="section-title">耗材管理</view>
      <view class="muted">可设置库存和预警线</view>
    </view>
    <view wx:for="{{supplies}}" wx:key="id" class="supply-row">
      <view class="row space-between align-start">
        <view>
          <view class="stock-name">{{item.name}}</view>
          <view class="muted mt-8">当前库存 {{item.stock}}{{item.unit}} · 预警线 {{item.warningLine}}{{item.unit}}</view>
          <view class="muted mt-8">{{item.statusText}}</view>
        </view>
        <view class="status-pill status-pill-{{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="supply-controls mt-16">
        <view class="control-group">
          <view class="muted">改库存</view>
          <view class="stock-controls">
            <view class="stock-btn" bindtap="changeSupplyStock" data-id="{{item.id}}" data-delta="-1">-</view>
            <view class="stock-btn" bindtap="changeSupplyStock" data-id="{{item.id}}" data-delta="1">+</view>
          </view>
        </view>
        <view class="control-group">
          <view class="muted">改预警线</view>
          <view class="stock-controls">
            <view class="stock-btn" bindtap="changeSupplyWarning" data-id="{{item.id}}" data-delta="-1">-</view>
            <view class="stock-btn" bindtap="changeSupplyWarning" data-id="{{item.id}}" data-delta="1">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'report'}}">
    <view class="section-title">日报统计</view>
    <view class="muted">{{reportText}}</view>
    <view class="btn mt-20" bindtap="copyReport">一键复制今日摘要</view>

    <view class="analytics-block">
      <view class="analytics-title">哪个汤最受欢迎</view>
      <view wx:for="{{analytics.topSoups}}" wx:key="name" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 份</text>
      </view>
    </view>

    <view class="analytics-block">
      <view class="analytics-title">哪个时段下单最多</view>
      <view wx:for="{{analytics.topHours}}" wx:key="hour" class="analytics-row">
        <text>{{item.hour}}</text>
        <text>{{item.count}} 单</text>
      </view>
    </view>

    <view class="analytics-block">
      <view class="analytics-title">高复购顾客</view>
      <view wx:for="{{analytics.topCustomers}}" wx:key="phone" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 单 · {{item.amount}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">店长常用动作</view>
    <view class="btn" bindtap="resetDemoData">重置演示数据</view>
  </view>
</view>
