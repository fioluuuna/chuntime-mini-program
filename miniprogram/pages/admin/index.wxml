<view class="page">
  <view class="card">
    <view class="title">店长后台</view>
    <view class="subtitle">手机上就能看订单、看库存、看日报，不需要导出表格也能先管起来。</view>
    <view class="mt-16">
      <text class="pill">仅库存确认</text>
      <text class="pill">仅售罄控制</text>
      <text class="pill">手机日报</text>
    </view>
  </view>

  <view class="grid-2">
    <view class="card stat-card" wx:for="{{summaryCards}}" wx:key="label">
      <view class="stat-label">{{item.label}}</view>
      <view class="stat-value">{{item.value}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">库存确认</view>
    <view class="muted mb-16">这里只保留“确认库存”和“售罄控制”，不自动算采购需求。</view>
    <view wx:for="{{stocks}}" wx:key="name" class="stock-row">
      <view class="row space-between">
        <view>
          <view class="stock-name">{{item.name}}</view>
          <view class="muted">剩余 {{item.remaining}} / 总 {{item.stock}}</view>
        </view>
        <view class="stock-controls">
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="-1">-</view>
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="1">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">手机日报</view>
    <view class="muted">{{reportText}}</view>
    <view class="btn mt-20" bindtap="copyReport">一键复制今日汇总</view>
  </view>

  <view class="card">
    <view class="section-title">数据分析</view>
    <view class="analytics-block">
      <view class="analytics-title">哪个汤最受欢迎</view>
      <view wx:for="{{analytics.topSoups}}" wx:key="name" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 份</text>
      </view>
    </view>
    <view class="analytics-block">
      <view class="analytics-title">哪个时段下单最多</view>
      <view wx:for="{{analytics.topHours}}" wx:key="hour" class="analytics-row">
        <text>{{item.hour}}</text>
        <text>{{item.count}} 单</text>
      </view>
    </view>
    <view class="analytics-block">
      <view class="analytics-title">高复购顾客</view>
      <view wx:for="{{analytics.topCustomers}}" wx:key="phone" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 单 · {{item.amount}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">订单流转</view>
    <view wx:for="{{orders}}" wx:key="id" class="order-admin-row">
      <view class="row space-between">
        <view>
          <view class="stock-name">{{item.id}} · {{item.name}}</view>
          <view class="muted">{{item.fulfillmentType}} · {{item.createdAt}}</view>
          <view class="muted mt-8">金额 ¥{{item.totals.total}}</view>
        </view>
        <view class="status-pill">{{item.status}}</view>
      </view>
      <view class="status-actions mt-16">
        <view class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="待接单">待接单</view>
        <view class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="备餐中">备餐中</view>
        <view class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="待取餐/配送中">待取餐</view>
        <view class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="已完成">完成</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">店长常用动作</view>
    <view class="admin-actions">
      <view class="action-item">
        <view class="action-title">改库存</view>
        <view class="muted">随时手动修改剩余份数</view>
      </view>
      <view class="action-item">
        <view class="action-title">看订单</view>
        <view class="muted">查看待接单、备餐中、待取餐</view>
      </view>
      <view class="action-item">
        <view class="action-title">看会员</view>
        <view class="muted">看积分、储值和券包情况</view>
      </view>
    </view>
    <view class="btn mt-20" bindtap="resetDemoData">重置演示数据</view>
  </view>
</view>
