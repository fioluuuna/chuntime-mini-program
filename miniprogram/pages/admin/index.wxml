<view class="page">
  <view class="card">
    <view class="section-head">
      <view>
        <view class="title">店长后台</view>
        <view class="subtitle">顾客端看不到这里。这里专门处理订单、库存、物料和日报。</view>
      </view>
      <view class="btn btn-ghost" bindtap="logout">退出</view>
    </view>

    <view wx:if="{{materialAlerts.length}}" class="alert-box">
      <view class="alert-title">物料预警</view>
      <view wx:for="{{materialAlerts}}" wx:key="id" class="muted mt-8">
        【{{item.groupLabel}}】{{item.name}} 仅剩 {{item.stock}}{{item.unit}}，低于预警线 {{item.warningLine}}{{item.unit}}
      </view>
    </view>
  </view>

  <view class="grid-2">
    <view class="card stat-card" wx:for="{{summaryCards}}" wx:key="label">
      <view class="stat-label">{{item.label}}</view>
      <view class="stat-value">{{item.value}}</view>
    </view>
  </view>

  <view class="card">
    <view class="module-chips">
      <view class="module-chip {{activeModule === 'orders' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="orders">订单管理</view>
      <view class="module-chip {{activeModule === 'products' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="products">菜品库存</view>
      <view class="module-chip {{activeModule === 'materials' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="materials">物料管理</view>
      <view class="module-chip {{activeModule === 'report' ? 'module-chip-active' : ''}}" bindtap="changeModule" data-module="report">日报统计</view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'orders'}}">
    <view class="section-head">
      <view class="section-title">订单管理</view>
      <view class="order-filters">
        <view class="filter-chip {{orderFilter === 'all' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="all">全部</view>
        <view class="filter-chip {{orderFilter === 'pending_payment' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="pending_payment">待付款</view>
        <view class="filter-chip {{orderFilter === 'pending_confirm' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="pending_confirm">待确认</view>
        <view class="filter-chip {{orderFilter === 'completed' ? 'filter-chip-active' : ''}}" bindtap="changeOrderFilter" data-filter="completed">已完成</view>
      </view>
    </view>

    <view wx:for="{{visibleOrders}}" wx:key="id" class="order-admin-row">
      <view class="row space-between align-start">
        <view class="order-detail">
          <view class="stock-name">{{item.id}} · {{item.name}}</view>
          <view class="muted mt-8">{{item.fulfillmentText}} · {{item.phone}}</view>
          <view class="muted mt-8 order-text">地址：{{item.address}}</view>
          <view wx:if="{{item.remark}}" class="muted mt-8 order-text">备注：{{item.remark}}</view>
          <view class="muted mt-8">{{item.createdAt}} · 金额 {{item.totals.total}}</view>
        </view>
        <view class="status-pill status-pill-{{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="status-actions mt-16">
        <view wx:if="{{item.status === 'pending_payment'}}" class="status-btn">等待顾客付款</view>
        <view wx:if="{{item.status === 'pending_confirm'}}" class="status-btn status-btn-primary" bindtap="stepOrder" data-id="{{item.id}}" data-status="completed">确认收款</view>
        <view wx:if="{{item.status !== 'completed'}}" class="status-btn" bindtap="stepOrder" data-id="{{item.id}}" data-status="completed">直接完成</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'products'}}">
    <view class="section-title">菜品库存管理</view>
    <view wx:for="{{stocks}}" wx:key="id" class="stock-row">
      <view class="row space-between">
        <view>
          <view class="stock-name">{{item.name}}</view>
          <view class="muted">{{item.category === 'soup' ? '炖汤' : '面食'}} · 当前库存 {{item.stock}}</view>
        </view>
        <view class="stock-controls">
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="-1">-</view>
          <view class="stock-btn" bindtap="changeStock" data-id="{{item.id}}" data-delta="1">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'materials'}}">
    <view class="section-head">
      <view>
        <view class="section-title">物料管理</view>
        <view class="muted">统一管理包材耗材和厨房食材/辅料，随时调整库存与预警线。</view>
      </view>
      <view class="tag">打开后台就知道缺什么</view>
    </view>

    <view wx:for="{{materialGroups}}" wx:key="key" class="material-group">
      <view class="material-group-head">
        <view class="material-group-title">{{item.title}}</view>
        <view class="muted">{{item.items.length}} 项</view>
      </view>

      <view wx:for="{{item.items}}" wx:key="id" class="material-row">
        <view class="row space-between align-start">
          <view>
            <view class="stock-name">{{item.name}}</view>
            <view class="muted mt-8">当前库存 {{item.stock}}{{item.unit}} · 预警线 {{item.warningLine}}{{item.unit}}</view>
          </view>
          <view class="status-pill status-pill-{{item.statusClass}}">{{item.statusText}}</view>
        </view>
        <view class="supply-controls mt-16">
          <view class="control-group">
            <view class="muted">改库存</view>
            <view class="stock-controls">
              <view class="stock-btn" bindtap="changeMaterialStock" data-id="{{item.id}}" data-delta="-1">-</view>
              <view class="stock-btn" bindtap="changeMaterialStock" data-id="{{item.id}}" data-delta="1">+</view>
            </view>
          </view>
          <view class="control-group">
            <view class="muted">改预警线</view>
            <view class="stock-controls">
              <view class="stock-btn" bindtap="changeMaterialWarning" data-id="{{item.id}}" data-delta="-1">-</view>
              <view class="stock-btn" bindtap="changeMaterialWarning" data-id="{{item.id}}" data-delta="1">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{activeModule === 'report'}}">
    <view class="section-head">
      <view>
        <view class="section-title">日报统计</view>
        <view class="muted">{{reportText}}</view>
      </view>
      <view class="btn btn-ghost" bindtap="copyReport">复制摘要</view>
    </view>

    <view class="ledger-panel">
      <view class="section-head ledger-head">
        <view>
          <view class="analytics-title">每日记账</view>
          <view class="muted">收入支出都能在手机上快速记录。</view>
        </view>
        <picker mode="date" value="{{ledgerDate}}" bindchange="changeLedgerDate">
          <view class="picker-chip">{{ledgerDate}}</view>
        </picker>
      </view>

      <view class="ledger-summary-grid">
        <view class="ledger-summary-card">
          <view class="ledger-summary-label">当日结余</view>
          <view class="ledger-summary-value">{{ledger.summary.balanceText}}</view>
        </view>
        <view class="ledger-summary-card">
          <view class="ledger-summary-label">总收入</view>
          <view class="ledger-summary-value income-text">{{ledger.summary.incomeText}}</view>
        </view>
        <view class="ledger-summary-card">
          <view class="ledger-summary-label">总支出</view>
          <view class="ledger-summary-value expense-text">{{ledger.summary.expenseText}}</view>
        </view>
      </view>

      <view class="ledger-form-grid">
        <view class="ledger-form-card">
          <view class="ledger-form-title">添加收入</view>
          <input class="input mt-16" type="digit" value="{{incomeAmount}}" bindinput="bindIncomeAmount" placeholder="收入金额" placeholder-class="field-placeholder" />
          <picker mode="selector" range="{{incomeSources}}" value="{{incomeSourceIndex}}" bindchange="changeIncomeSource">
            <view class="picker-field mt-16">来源：{{incomeSources[incomeSourceIndex]}}</view>
          </picker>
          <input class="input mt-16" value="{{incomeRemark}}" bindinput="bindIncomeRemark" placeholder="备注，可不填" placeholder-class="field-placeholder" />
          <view class="btn mt-20" bindtap="submitIncome">记录收入</view>
        </view>

        <view class="ledger-form-card">
          <view class="ledger-form-title">添加支出</view>
          <input class="input mt-16" type="digit" value="{{expenseAmount}}" bindinput="bindExpenseAmount" placeholder="支出金额" placeholder-class="field-placeholder" />
          <picker mode="selector" range="{{expenseCategories}}" value="{{expenseCategoryIndex}}" bindchange="changeExpenseCategory">
            <view class="picker-field mt-16">分类：{{expenseCategories[expenseCategoryIndex]}}</view>
          </picker>
          <input class="input mt-16" value="{{expenseRemark}}" bindinput="bindExpenseRemark" placeholder="备注，可不填" placeholder-class="field-placeholder" />
          <view class="btn btn-warm mt-20" bindtap="submitExpense">记录支出</view>
        </view>
      </view>

      <view class="ledger-lists">
        <view class="ledger-list-card">
          <view class="ledger-form-title">收入记录</view>
          <view wx:if="{{ledger.incomeEntries.length === 0}}" class="muted mt-16">当天还没有收入记录</view>
          <view wx:for="{{ledger.incomeEntries}}" wx:key="id" class="ledger-entry">
            <view class="row space-between align-start">
              <view class="ledger-entry-main">
                <view class="stock-name">{{item.source}}</view>
                <view wx:if="{{item.remark}}" class="muted mt-8 order-text">{{item.remark}}</view>
                <view class="muted mt-8">{{item.createdAt}}</view>
              </view>
              <view class="ledger-amount income-text">+{{item.amount}}</view>
            </view>
          </view>
        </view>

        <view class="ledger-list-card">
          <view class="ledger-form-title">支出记录</view>
          <view wx:if="{{ledger.expenseEntries.length === 0}}" class="muted mt-16">当天还没有支出记录</view>
          <view wx:for="{{ledger.expenseEntries}}" wx:key="id" class="ledger-entry">
            <view class="row space-between align-start">
              <view class="ledger-entry-main">
                <view class="stock-name">{{item.category}}</view>
                <view wx:if="{{item.remark}}" class="muted mt-8 order-text">{{item.remark}}</view>
                <view class="muted mt-8">{{item.createdAt}}</view>
              </view>
              <view class="ledger-amount expense-text">-{{item.amount}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="analytics-block">
      <view class="analytics-title">哪个汤最受欢迎</view>
      <view wx:for="{{analytics.topSoups}}" wx:key="name" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 份</text>
      </view>
    </view>

    <view class="analytics-block">
      <view class="analytics-title">哪个时段下单最多</view>
      <view wx:for="{{analytics.topHours}}" wx:key="hour" class="analytics-row">
        <text>{{item.hour}}</text>
        <text>{{item.count}} 单</text>
      </view>
    </view>

    <view class="analytics-block">
      <view class="analytics-title">高复购顾客</view>
      <view wx:for="{{analytics.topCustomers}}" wx:key="phone" class="analytics-row">
        <text>{{item.name}}</text>
        <text>{{item.count}} 单 · {{item.amount}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">店长常用动作</view>
    <view class="btn" bindtap="resetDemoData">重置演示数据</view>
  </view>
</view>
