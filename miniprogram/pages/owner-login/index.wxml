<view class="page">
  <view class="card">
    <view class="title">店长验证</view>
    <view class="subtitle mt-8">如果你是店长，也可以在这里输入密码进入后台。</view>
    <input class="login-input" password placeholder="请输入店长密码" placeholder-class="field-placeholder" bindinput="bindInput" value="{{code}}" />
    <view class="btn mt-20" bindtap="submit">{{loading ? '验证中...' : '进入后台'}}</view>
  </view>
</view>
